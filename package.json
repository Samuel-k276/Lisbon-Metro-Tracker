{
  "name": "metro-de-lisboa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "oxlint -c .oxlintrc.json src/",
    "fmt": "oxfmt src/",
    "fmt:check": "oxfmt --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "konva": "^10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-konva": "^19.0.3",
    "react-router-dom": "^7"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "sass": "^1.99.0",
    "typescript": "^6",
    "vite": "^8",
    "vitest": "^4.1.4"
  }
}
